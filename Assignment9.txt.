#include <iostream>
#include <string>

using namespace std;

// The Class serves as the "Blueprint"
class Student {
public:
    // Attributes
    string name;
    int idNumber;
    string major;

    // Constructor
    Student(string n, int id, string m) {
        name = n;
        idNumber = id;
        major = m;
    }

    // Method to display the data
    void displayInfo() {
        cout << "============================" << endl;
        cout << "      STUDENT RECORD        " << endl;
        cout << "============================" << endl;
        cout << "Name:     " << name << endl;
        cout << "ID:       " << idNumber << endl;
        cout << "Major:    " << major << endl;
        cout << "============================" << endl;
    }
};

int main() {
    // Replace the details below with your information
    Student student1("Asma Alali", 123456, "Computer Science");

    // Calling the method
    student1.displayInfo();

    return 0;
}
